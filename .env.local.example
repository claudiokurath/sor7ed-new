# --- Site -------------------------------------------------------------
# Where magic-link emails should redirect users back to.
# Use http://localhost:3000 for local dev; https://sor7ed.com in prod.
NEXT_PUBLIC_SITE_URL=https://sor7ed.com

# --- Notion (CMS + CRM) -----------------------------------------------
